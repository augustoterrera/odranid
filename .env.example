OPENAI_API_KEY=sk-...
ODRANID_AGENT_MODEL=gpt-4.1-mini

# Primary production backend: direct Postgres with pgvector.
ODRANID_DATABASE_URL=postgresql://odranid:PASSWORD@100.x.y.z:5432/odranid_catalog
POSTGRES_DB=odranid
POSTGRES_USER=odranid
POSTGRES_PASSWORD=CAMBIAR_PASSWORD

# Local fixture only. Production/runtime uses WooCommerce.
ODRANID_CATALOG_FILE=productos.json

# Direct WooCommerce ingestion. This is the default source.
ODRANID_WOOCOMMERCE_BASE_URL=https://odranid.com.ar
ODRANID_WOOCOMMERCE_PER_PAGE=100
ODRANID_WOOCOMMERCE_MAX_PAGES=50
ODRANID_WOOCOMMERCE_STOCK_STATUS=instock,outofstock

# Chatwoot webhook + reply API.
ODRANID_CHATWOOT_BASE_URL=https://chatwoot.tu-dominio.com
ODRANID_CHATWOOT_ACCOUNT_ID=1
ODRANID_CHATWOOT_API_ACCESS_TOKEN=TU_API_ACCESS_TOKEN
ODRANID_CHATWOOT_WEBHOOK_SECRET=TU_WEBHOOK_SECRET
# En produccion: true. Si esta en true y falta el WEBHOOK_SECRET, el arranque aborta
# (no acepta webhooks sin firmar). Default: false (comodo para dev local).
ODRANID_REQUIRE_WEBHOOK_SECRET=false
ODRANID_CHATWOOT_AUTO_REPLY=true
ODRANID_CHATWOOT_AGENT_LIMIT=5
ODRANID_CHATWOOT_HISTORY_LIMIT=16
ODRANID_CHAT_MEMORY_ENABLED=true
ODRANID_CHATWOOT_LOCK_SECONDS=60
ODRANID_CHATWOOT_LOCK_WAIT_SECONDS=20
ODRANID_CHATWOOT_DEBOUNCE_SECONDS=5
ODRANID_CHATWOOT_DEBOUNCE_RETRY_SECONDS=3
ODRANID_CHATWOOT_JOB_MAX_RETRIES=5
ODRANID_CHATWOOT_OUTBOX_MAX_RETRIES=5
ODRANID_CHATWOOT_STALE_PROCESSING_MINUTES=15
ODRANID_TYPESENSE_HOST=localhost
ODRANID_TYPESENSE_PORT=8108
ODRANID_TYPESENSE_PROTOCOL=http
ODRANID_TYPESENSE_API_KEY=localdevkey
ODRANID_TYPESENSE_COLLECTION=catalog_products
# Routea /search por Typesense (backend de busqueda elegido). Cae a pgvector solo
# si no hay API key de Typesense. El indice se refresca cada N minutos via beat.
ODRANID_TYPESENSE_SEARCH_ENABLED=true
ODRANID_TYPESENSE_SYNC_MINUTES=30
# WooCommerce -> Postgres se sincroniza cada N minutos via beat. Default: 60.
ODRANID_CATALOG_SYNC_MINUTES=60
ODRANID_CELERY_BROKER_URL=redis://localhost:6379/0
ODRANID_CELERY_RESULT_BACKEND=redis://localhost:6379/1
ODRANID_CELERY_TIMEZONE=America/Argentina/Tucuman

# Seguridad / performance (produccion)
# Token para los endpoints /admin/* (reload, fetch-woocommerce, sync-catalog, typesense-sync).
# Si esta vacio, admin queda DESHABILITADO (responde 503). Obligatorio en prod.
ODRANID_ADMIN_API_TOKEN=
# TTL (segundos) del contexto de catalogo cacheado: evita recalcular facetas de
# Postgres (~3s) en cada mensaje. Se invalida solo al sincronizar/recargar. Default 300.
ODRANID_CATALOG_CONTEXT_TTL_SECONDS=300
