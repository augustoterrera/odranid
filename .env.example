# Copiar a .env y completar. Mantiene visibles las variables que cambian
# comportamiento real en produccion o desarrollo local.

# ============================================================
# Core / IA
# ============================================================
OPENAI_API_KEY=sk-...
ODRANID_AGENT_MODEL=gpt-4.1-mini
ODRANID_EMBEDDING_MODEL=text-embedding-3-small


# ============================================================
# Postgres / catalogo persistido
# ============================================================
ODRANID_DATABASE_URL=postgresql://odranid:odranid@postgres:5432/odranid


# ============================================================
# WooCommerce -> Postgres
# ============================================================
ODRANID_WOOCOMMERCE_BASE_URL=https://odranid.com.ar
ODRANID_WOOCOMMERCE_PER_PAGE=100
ODRANID_WOOCOMMERCE_MAX_PAGES=50
ODRANID_WOOCOMMERCE_STOCK_STATUS=instock,outofstock
ODRANID_CATALOG_SYNC_MINUTES=60


# ============================================================
# Typesense
# ============================================================
ODRANID_TYPESENSE_API_KEY=localdevkey
ODRANID_TYPESENSE_SYNC_MINUTES=30

# Si corres la app fuera de docker-compose, puede hacer falta apuntar al host real.
# En docker-compose, los servicios app/worker ya reciben ODRANID_TYPESENSE_HOST=typesense.
# ODRANID_TYPESENSE_HOST=localhost
# ODRANID_TYPESENSE_PORT=8108
# ODRANID_TYPESENSE_PROTOCOL=http


# ============================================================
# Chatwoot
# ============================================================
ODRANID_CHATWOOT_BASE_URL=https://chatwoot.tu-dominio.com
ODRANID_CHATWOOT_ACCOUNT_ID=1
ODRANID_CHATWOOT_API_ACCESS_TOKEN=CAMBIAR_TOKEN_CHATWOOT
ODRANID_CHATWOOT_WEBHOOK_SECRET=CAMBIAR_SECRET_WEBHOOK
ODRANID_REQUIRE_WEBHOOK_SECRET=true

ODRANID_CHATWOOT_AUTO_REPLY=true
ODRANID_CHATWOOT_AGENT_LIMIT=5
ODRANID_CHATWOOT_HISTORY_LIMIT=8
ODRANID_CHAT_MEMORY_ENABLED=true


# ============================================================
# Seguridad / exposicion publica
# ============================================================
ODRANID_PUBLIC_DOMAIN=odranid.tu-dominio.com
ODRANID_ADMIN_API_TOKEN=CAMBIAR_TOKEN_ADMIN


# ============================================================
# Docker / infraestructura
# ============================================================
# Procesos uvicorn de la API. Ajustar segun CPU/RAM.
API_WORKERS=2

# Dragonfly en VPS chicos necesita menos threads/memoria explicita.
DRAGONFLY_PROACTOR_THREADS=1
DRAGONFLY_MAXMEMORY=256mb

# Solo si usas el perfil observability de docker-compose.
FLOWER_BASIC_AUTH=admin:CAMBIAR_PASSWORD

# Solo si usas el perfil local-db y queres cambiar los defaults del contenedor.
# POSTGRES_DB=odranid
# POSTGRES_USER=odranid
# POSTGRES_PASSWORD=CAMBIAR_PASSWORD


# ============================================================
# Ajustes avanzados
# ============================================================
# Normalmente no hace falta tocarlos.
# ODRANID_VECTOR_TOP_K=50
# ODRANID_CHATWOOT_WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300
# ODRANID_CHATWOOT_LOCK_SECONDS=60
# ODRANID_CHATWOOT_LOCK_WAIT_SECONDS=20
# ODRANID_CHATWOOT_DEBOUNCE_SECONDS=5
# ODRANID_CHATWOOT_DEBOUNCE_RETRY_SECONDS=3
# ODRANID_CHATWOOT_JOB_MAX_RETRIES=5
# ODRANID_CHATWOOT_OUTBOX_MAX_RETRIES=5
# ODRANID_CHATWOOT_STALE_PROCESSING_MINUTES=15

# Solo si corres Celery fuera de docker-compose.
# ODRANID_CELERY_BROKER_URL=redis://localhost:6379/0
# ODRANID_CELERY_RESULT_BACKEND=redis://localhost:6379/1
# ODRANID_CELERY_TIMEZONE=America/Argentina/Tucuman

# Solo para desarrollo con snapshot local en vez de DB.
# ODRANID_CATALOG_FILE=data/productos.json
