# ============================================================
# App base
# ============================================================
# Nombre visible de la app FastAPI. Opcional. Default: odranid-catalog-service.
ODRANID_APP_NAME=odranid-catalog-service

# Snapshot local del catalogo para dev sin DB. Opcional. Default: data/productos.json.
# En produccion la fuente de verdad es Postgres; este archivo queda como fallback local.
ODRANID_CATALOG_FILE=data/productos.json

# Prompt institucional/conversacional del agente. Opcional. Default: app/agents/prompts/prompt_agente_odranid.md.
ODRANID_AGENT_PROMPT_FILE=app/agents/prompts/prompt_agente_odranid.md

# Archivo de cache legacy del contexto local. Opcional. Default: /tmp/odranid_catalog_context.txt.
ODRANID_CONTEXT_CACHE_FILE=/tmp/odranid_catalog_context.txt

# TTL en segundos del contexto de catalogo calculado desde Postgres. Opcional. Default: 300.
ODRANID_CATALOG_CONTEXT_TTL_SECONDS=300


# ============================================================
# OpenAI (obligatorio para agente, embeddings y busqueda semantica)
# ============================================================
# API key de OpenAI. Obligatoria para agente y embeddings. Default: sin configurar.
OPENAI_API_KEY=sk-...
# Alias tambien aceptado por la app. Usar solo uno de los dos.
# ODRANID_OPENAI_API_KEY=sk-...

# Modelo de chat del agente. Opcional. Default: gpt-4.1-mini.
ODRANID_AGENT_MODEL=gpt-4.1-mini

# Modelo de embeddings. Opcional. Default: text-embedding-3-small (1536 dimensiones).
ODRANID_EMBEDDING_MODEL=text-embedding-3-small

# Cantidad de candidatos vectoriales para busqueda pgvector. Opcional. Default: 50.
ODRANID_VECTOR_TOP_K=50


# ============================================================
# Postgres + pgvector (obligatorio en produccion)
# ============================================================
# URL de Postgres con pgvector. Obligatoria en produccion. Default: sin configurar.
ODRANID_DATABASE_URL=postgresql://odranid:PASSWORD@100.x.y.z:5432/odranid_catalog

# Variables del contenedor Postgres local. No son Settings de la app.
POSTGRES_DB=odranid
POSTGRES_USER=odranid
POSTGRES_PASSWORD=CAMBIAR_PASSWORD


# ============================================================
# WooCommerce (fuente de catalogo)
# ============================================================
# URL base de la tienda WooCommerce. Opcional. Default: https://odranid.com.ar.
ODRANID_WOOCOMMERCE_BASE_URL=https://odranid.com.ar

# Productos por pagina al leer WooCommerce. Opcional. Default: 100.
ODRANID_WOOCOMMERCE_PER_PAGE=100

# Maximo de paginas a leer desde WooCommerce. Opcional. Default: 50.
ODRANID_WOOCOMMERCE_MAX_PAGES=50

# Stock statuses incluidos en la ingesta. Opcional. Default: instock,outofstock.
ODRANID_WOOCOMMERCE_STOCK_STATUS=instock,outofstock

# Frecuencia en minutos del sync WooCommerce -> Postgres via beat. Opcional. Default: 60.
ODRANID_CATALOG_SYNC_MINUTES=60


# ============================================================
# Chatwoot (webhook de entrada y API de respuesta)
# ============================================================
# URL base de Chatwoot. Obligatoria para responder mensajes. Default: sin configurar.
ODRANID_CHATWOOT_BASE_URL=https://chatwoot.tu-dominio.com

# Account ID de Chatwoot. Obligatorio para responder mensajes. Default: sin configurar.
ODRANID_CHATWOOT_ACCOUNT_ID=1

# Token API de Chatwoot. Obligatorio para responder mensajes. Default: sin configurar.
ODRANID_CHATWOOT_API_ACCESS_TOKEN=TU_API_ACCESS_TOKEN

# Secret HMAC del webhook entrante. Obligatorio en produccion. Default: sin configurar.
ODRANID_CHATWOOT_WEBHOOK_SECRET=TU_WEBHOOK_SECRET

# Tolerancia en segundos para timestamp del webhook firmado. Opcional. Default: 300.
ODRANID_CHATWOOT_WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300

# Si true, la app aborta el arranque cuando falta el webhook secret. Opcional. Default: false.
ODRANID_REQUIRE_WEBHOOK_SECRET=false

# Si true, responde automaticamente a Chatwoot. Opcional. Default: true.
ODRANID_CHATWOOT_AUTO_REPLY=true

# Cantidad maxima de productos que el agente puede pedir. Opcional. Default: 5.
ODRANID_CHATWOOT_AGENT_LIMIT=5

# Cantidad de mensajes recientes usados como historial. Opcional. Default: 16.
ODRANID_CHATWOOT_HISTORY_LIMIT=16

# Habilita memoria conversacional persistida en Postgres. Opcional. Default: true.
ODRANID_CHAT_MEMORY_ENABLED=true

# TTL en segundos del lock por conversacion. Opcional. Default: 60.
ODRANID_CHATWOOT_LOCK_SECONDS=60

# Tiempo maximo en segundos esperando lock de conversacion. Opcional. Default: 20.
ODRANID_CHATWOOT_LOCK_WAIT_SECONDS=20

# Debounce en segundos antes de procesar mensajes agrupados. Opcional. Default: 5.
ODRANID_CHATWOOT_DEBOUNCE_SECONDS=5

# Reintento en segundos cuando el debounce detecta mensajes nuevos. Opcional. Default: 3.
ODRANID_CHATWOOT_DEBOUNCE_RETRY_SECONDS=3

# Reintentos maximos de jobs de conversacion. Opcional. Default: 5.
ODRANID_CHATWOOT_JOB_MAX_RETRIES=5

# Reintentos maximos de mensajes outbox. Opcional. Default: 5.
ODRANID_CHATWOOT_OUTBOX_MAX_RETRIES=5

# Minutos para considerar stale un job en processing. Opcional. Default: 15.
ODRANID_CHATWOOT_STALE_PROCESSING_MINUTES=15


# ============================================================
# Celery / Dragonfly
# ============================================================
# Broker Redis/Dragonfly para Celery. Opcional. Default: redis://localhost:6379/0.
ODRANID_CELERY_BROKER_URL=redis://localhost:6379/0

# Backend de resultados de Celery. Opcional. Default: redis://localhost:6379/1.
ODRANID_CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Timezone de Celery beat. Opcional. Default: America/Argentina/Tucuman.
ODRANID_CELERY_TIMEZONE=America/Argentina/Tucuman


# ============================================================
# Typesense (indice de busqueda activo)
# ============================================================
# Host de Typesense. Opcional. Default: localhost.
ODRANID_TYPESENSE_HOST=localhost

# Puerto de Typesense. Opcional. Default: 8108.
ODRANID_TYPESENSE_PORT=8108

# Protocolo de Typesense. Opcional. Default: http.
ODRANID_TYPESENSE_PROTOCOL=http

# API key de Typesense. Obligatoria para usar Typesense. Default: sin configurar.
ODRANID_TYPESENSE_API_KEY=localdevkey

# Coleccion de catalogo en Typesense. Opcional. Default: catalog_products.
ODRANID_TYPESENSE_COLLECTION=catalog_products

# Si true, /search usa Typesense cuando hay API key. Opcional. Default: true.
ODRANID_TYPESENSE_SEARCH_ENABLED=true

# Frecuencia en minutos del refresh de Typesense via beat. Opcional. Default: 30.
ODRANID_TYPESENSE_SYNC_MINUTES=30


# ============================================================
# Seguridad admin
# ============================================================
# Token para /admin/* (reload, fetch-woocommerce, sync-catalog, typesense-sync).
# Obligatorio en produccion. Si falta, admin queda deshabilitado (503). Default: sin configurar.
ODRANID_ADMIN_API_TOKEN=


# ============================================================
# Infra / despliegue (docker-compose) - no son Settings de la app
# ============================================================
# Dominio publico del reverse proxy (perfil "proxy", Caddy con HTTPS automatico).
ODRANID_PUBLIC_DOMAIN=odranid.tu-dominio.com

# Basic auth del panel Flower (perfil "observability"). Cambiar en produccion.
FLOWER_BASIC_AUTH=admin:CAMBIAR_PASSWORD

# Procesos uvicorn de la API. Ajustar segun CPU/RAM del VPS. Default compose: 2.
API_WORKERS=2

# Topes de memoria por servicio (solo frenan runaways; ajustar a la RAM del VPS).
# POSTGRES_MEM_LIMIT=2g
# TYPESENSE_MEM_LIMIT=2g
# DRAGONFLY_MEM_LIMIT=1g
# API_MEM_LIMIT=1g
# WORKER_MEM_LIMIT=1g
# CATALOG_WORKER_MEM_LIMIT=1500m
